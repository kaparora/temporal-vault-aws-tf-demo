# ── Temporal Cloud Access ─────────────────────────────────────────────────────
TEMPORAL_ADDRESS_INFRA=<your-namespace>.<account-id>.tmprl.cloud:7233
TEMPORAL_NAMESPACE=<your-namespace>
TEMPORAL_TLS_CERT=<path-to-client.pem>
TEMPORAL_TLS_KEY=<path-to-client.key>

# ── Temporal Cloud Provisioning (for Terraform) ────────────────────────────────
TEMPORAL_CLOUD_API_KEY=<api-key-or-/path/to/api_key_file>  # can be inline or file path
TEMPORAL_NAMESPACE_FOR_ORDERS=<your-namespace>-orders      # new namespace for order workflows

# ── HCP Vault Provisioning (for Terraform) ────────────────────────────────────
PROVISION_HCP_VAULT_CLUSTER=true             # set to false to skip cluster creation and use existing
HCP_CLIENT_ID=<service-principal-client-id>
HCP_CLIENT_SECRET=<service-principal-client-secret>
HCP_PROJECT_ID=<your-hcp-project-id>

# ── HCP Vault Access ──────────────────────────────────────────────────────────
HCP_VAULT_ADDR=https://vault-cluster.<region>.hashicorp.cloud:8200
HCP_VAULT_NAMESPACE=admin
HCP_VAULT_TOKEN=<your-vault-token>          # used for bootstrap + terraform config
VAULT_ROLE=temporal-worker                  # Vault AWS IAM role name (for EC2 worker)

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=<your-access-key>
AWS_SECRET_ACCESS_KEY=<your-secret-key>

# ── Deployment ────────────────────────────────────────────────────────────────
GIT_REPO_URL=<https://github.com/user/repo>  # repo to clone on EC2 for worker
GIT_BRANCH=main                              # branch to clone

# ── Database (populated from Terraform outputs after apply) ───────────────────
DB_HOST=<rds-endpoint>
DB_PORT=5432
DB_NAME=ordersdb
DB_ADMIN_USER=postgres

# ── Worker identity ───────────────────────────────────────────────────────────
AUTH_METHOD=token                           # token (local) | iam (EC2)
TASK_QUEUE=orders-tq

# ── Bootstrap ─────────────────────────────────────────────────────────────────
BOOTSTRAP_TASK_QUEUE=bootstrap-tq
ORDERS_TASK_QUEUE=orders-tq
TERRAFORM_DIR=./terraform
