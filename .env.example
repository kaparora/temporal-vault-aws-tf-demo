# ── Temporal Cloud — Infra/Bootstrap Worker ───────────────────────────────────
# The bootstrap namespace is created manually in Temporal Cloud before running
# the bootstrap workflow. The orders namespace is provisioned by Terraform.
TEMPORAL_ADDRESS_INFRA=<your-namespace>.<account-id>.tmprl.cloud:7233  # mTLS endpoint of the bootstrap namespace
TEMPORAL_NAMESPACE=<your-namespace>                                     # bootstrap namespace name (not the orders namespace)
TEMPORAL_TLS_CERT=<path-to-client.pem>  # mTLS cert for infra worker; orders worker certs are provisioned by Terraform
TEMPORAL_TLS_KEY=<path-to-client.key>   # mTLS key for infra worker

# ── Temporal Cloud — Provisioning (Terraform) ─────────────────────────────────
TEMPORAL_CLOUD_API_KEY=<api-key>        # Temporal Cloud API key used by Terraform to provision the orders namespace
TEMPORAL_NAMESPACE_FOR_ORDERS=<your-namespace>-orders  # orders namespace name to create via Terraform

# ── HCP — Provisioning (Terraform) ────────────────────────────────────────────
PROVISION_HCP_VAULT_CLUSTER=true        # set to false to use an existing Vault cluster
HCP_CLIENT_ID=<service-principal-client-id>      # HCP service principal for the Terraform HCP provider
HCP_CLIENT_SECRET=<service-principal-client-secret>
HCP_PROJECT_ID=<your-hcp-project-id>

# ── HCP Vault — Access (PROVISION_HCP_VAULT_CLUSTER=false only — NOT TESTED) ──
# Only needed when reusing a pre-existing HCP Vault cluster. Not required when
# provisioning a new cluster (PROVISION_HCP_VAULT_CLUSTER=true, the default).
# HCP_VAULT_ADDR=https://vault-cluster.<region>.hashicorp.cloud:8200
# HCP_VAULT_NAMESPACE=admin
# HCP_VAULT_TOKEN=<your-vault-token>    # initial admin token; no longer valid after root credential rotation in step 7
VAULT_ROLE=temporal-worker              # Vault auth role name (bound to the EC2 IAM role via AWS IAM auth method)

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=<your-access-key>
AWS_SECRET_ACCESS_KEY=<your-secret-key>

# ── Deployment ────────────────────────────────────────────────────────────────
GIT_REPO_URL=https://github.com/kaparora/temporal-vault-aws-tf-demo  # if you forked this repo, update to your own fork URL; cloned onto EC2 at boot
GIT_BRANCH=main

# ── Database ──────────────────────────────────────────────────────────────────
# DB_HOST and DB_PORT are injected into the EC2 worker automatically via
# Terraform userdata — they are not needed on the laptop.
DB_NAME=ordersdb        # name of the PostgreSQL database for order fulfillment
DB_ADMIN_USER=postgres  # database admin username

# ── Workers ────────────────────────────────────────────────────────────────────
BOOTSTRAP_TASK_QUEUE=bootstrap-tq # task queue for the infra/bootstrap worker
ORDERS_TASK_QUEUE=orders-tq       # task queue for the order fulfillment worker

# ── Bootstrap ─────────────────────────────────────────────────────────────────
TERRAFORM_DIR=./terraform          # root directory containing Terraform module subdirectories
